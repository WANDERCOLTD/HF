{
  "$schema": "./lattice-chains-schema.json",
  "$comment": "Machine-readable Lattice chain manifest. Story #2057. Walked by tests/lib/lattice-chain-closure.test.ts. Validated against docs/lattice-chains.md by lattice-self-maintenance.test.ts.",
  "version": 1,
  "chains": [
    {
      "id": "beh-aggregate-cascade",
      "title": "Behavior Aggregation Cascade (BEH-AGG-001 + ADAPT-BEH-001)",
      "description": "Per-call BEH-* CallScore \u2192 rolled-up behavior_profile:* CallerAttribute \u2192 ADAPT-BEH-001 CallerTarget upsert \u2192 composed prompt section. ADAPT leg closed by story #2074 (Phase 1 = 3 of 9 buckets: companion / supervision / engagement).",
      "links": [
        {
          "stage": "MEASURE",
          "producer": "apps/admin/lib/measurement/write-call-score.ts",
          "outputKey": "CallScore.parameterId",
          "outputKeySamples": [
            "BEH-CONVERSATIONAL-DEPTH",
            "BEH-WARMTH",
            "BEH-PATIENCE-LEVEL"
          ],
          "kind": "row-write"
        },
        {
          "stage": "AGGREGATE",
          "consumer": "apps/admin/docs-archive/bdd-specs/BEH-AGG-001-behavior-aggregation.spec.json",
          "consumesKey": "parameters[].config.aggregationRules[].sourceParameter",
          "consumesKeySamples": [
            "BEH-CONVERSATIONAL-DEPTH",
            "BEH-WARMTH",
            "BEH-PATIENCE-LEVEL"
          ],
          "outputKey": "CallerAttribute(scope=BEH-AGG-001, key=behavior_profile:{group}:{dimension})",
          "outputKeySamples": [
            "behavior_profile:companion:engagement_level",
            "behavior_profile:supervision:tutor_fidelity",
            "behavior_profile:engagement:cognitive_activation"
          ],
          "kind": "callerAttribute-write",
          "runner": "apps/admin/lib/pipeline/aggregate-runner.ts"
        },
        {
          "stage": "ADAPT",
          "consumer": "apps/admin/docs-archive/bdd-specs/ADAPT-BEH-001-behavior-adaptation.spec.json",
          "consumesKey": "parameters[].config.adaptationRules[].condition.profileKey (with dataSource=callerAttribute, scope defaults to BEH-AGG-001)",
          "consumesKeySamples": [
            "behavior_profile:companion:engagement_level",
            "behavior_profile:supervision:tutor_fidelity",
            "behavior_profile:engagement:cognitive_activation"
          ],
          "outputKey": "CallerTarget(callerId, parameterId={parameter}).targetValue",
          "outputKeySamples": [
            "BEH-ENGAGEMENT",
            "BEH-DEFINITION-PRECISION",
            "BEH-INTELLECTUAL-CHALLENGE",
            "BEH-FORMALITY",
            "BEH-DIRECTNESS",
            "BEH-WARMTH",
            "BEH-QUESTION-RATE"
          ],
          "kind": "row-write",
          "runner": "apps/admin/lib/pipeline/adapt-runner.ts",
          "outputNotes": "Phase 1 covers 3 of 9 BEH-AGG-001 buckets (companion / supervision / engagement). Deliberately avoids BEH-EMPATHY-RATE + BEH-PROACTIVE (owned by ADAPT-PERS-001). Remaining 6 buckets (personality / curriculum / learning / reinforcement / onboarding / core_style) deferred to Phase 2."
        },
        {
          "stage": "COMPOSE",
          "consumer": "apps/admin/lib/prompt/composition/transforms/quickstart.ts",
          "consumesKey": "CallerAttribute.scope === config.specs.aggBehavior",
          "consumesKeySamples": [
            "BEH-AGG-001"
          ],
          "outputKey": "learning_guidance section text",
          "kind": "section-emit",
          "outputNotes": "Emitted as 'Companion profile signals' / 'Personality profile signals' / etc. sub-sections via behaviorAttrs grouped by namespace prefix. The CallerTarget written by ADAPT (link 3) is read by the targets.ts transform at compose time \u2014 see chain `behavior-target-cascade`."
        }
      ]
    },
    {
      "id": "skill-ema-cascade",
      "title": "Skill EMA Aggregation Cascade (SKILL-AGG-001)",
      "description": "Per-call skill_* CallScore \u2192 time-decay EMA into CallerTarget.currentScore \u2192 ACHIEVE goal progress.",
      "links": [
        {
          "stage": "MEASURE",
          "producer": "apps/admin/lib/measurement/write-call-score.ts",
          "outputKey": "CallScore.parameterId",
          "outputKeySamples": [
            "skill_speaking_fluency",
            "skill_pronunciation",
            "skill_grammar"
          ],
          "kind": "row-write"
        },
        {
          "stage": "AGGREGATE",
          "consumer": "apps/admin/docs-archive/bdd-specs/SKILL-AGG-001-skill-ema-aggregation.spec.json",
          "consumesKey": "parameters[].config.aggregationRules[].sourceParameterPattern",
          "consumesKeySamples": [
            "skill_*"
          ],
          "outputKey": "CallerTarget.currentScore",
          "kind": "callerTarget-write",
          "runner": "apps/admin/lib/pipeline/aggregate-runner.ts",
          "method": "ema_to_caller_target"
        },
        {
          "stage": "ACHIEVE-GOAL",
          "consumer": "apps/admin/lib/goals/strategies/skill_ema.ts",
          "consumesKey": "CallerTarget.currentScore",
          "outputKey": "Goal.progress numeric value",
          "kind": "goal-progress-update"
        }
      ]
    },
    {
      "id": "coach-aggregate-cascade",
      "title": "Coaching Aggregation Cascade (COACH-AGG-001)",
      "description": "Per-call COACH_* CallScore \u2192 threshold-mapped CallerAttribute \u2192 composed prompt section via quickstart.ts learning_guidance.",
      "links": [
        {
          "stage": "MEASURE",
          "producer": "apps/admin/lib/measurement/write-call-score.ts",
          "outputKey": "CallScore.parameterId",
          "outputKeySamples": [
            "COACH_CLARITY",
            "COACH_ACTION",
            "COACH_AWARENESS",
            "COACH_FOLLOWUP"
          ],
          "kind": "row-write"
        },
        {
          "stage": "AGGREGATE",
          "consumer": "apps/admin/docs-archive/bdd-specs/COACH-AGG-001-coaching-aggregation.spec.json",
          "consumesKey": "parameters[].config.aggregationRules[].sourceParameter",
          "consumesKeySamples": [
            "COACH_CLARITY",
            "COACH_ACTION"
          ],
          "outputKey": "CallerAttribute(scope=COACH-AGG-001, key={goal_clarity,action_commitment,self_awareness,follow_through,competency_level})",
          "kind": "callerAttribute-write",
          "runner": "apps/admin/lib/pipeline/aggregate-runner.ts"
        },
        {
          "stage": "COMPOSE",
          "consumer": "apps/admin/lib/prompt/composition/transforms/quickstart.ts",
          "consumesKey": "CallerAttribute.scope === config.specs.aggCoaching",
          "consumesKeySamples": [
            "goal_clarity",
            "action_commitment",
            "self_awareness",
            "follow_through"
          ],
          "outputKey": "learning_guidance section text",
          "kind": "section-emit"
        }
      ]
    }
  ]
}