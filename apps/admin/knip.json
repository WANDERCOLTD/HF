{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/page.tsx",
    "app/**/layout.tsx",
    "app/**/route.ts",
    "app/api/**/route.ts",
    "middleware.ts",
    "next.config.ts",
    "next-env.d.ts",
    "scripts/*.{ts,sh}",
    "tests/**/*.test.{ts,tsx}",
    "tests/**/*.spec.{ts,tsx}",
    "__tests__/**/*.test.{ts,tsx}",
    "e2e/**/*.spec.ts",
    "lib/wizard/__tests__/**/*.test.{ts,tsx}",
    "prisma/seed*.ts",
    "prisma/seed/**/*.ts",
    "cli/control.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "ignore": [
    "**/.next/**",
    "**/node_modules/**",
    "**/_archived/**",
    "**/*.bak",
    "prisma/migrations/**",
    "docs-archive/**"
  ],
  "ignoreDependencies": [
    "@types/*"
  ],
  "ignoreExportsUsedInFile": true,
  "next": {
    "entry": [
      "app/**/page.tsx",
      "app/**/layout.tsx",
      "app/**/route.ts",
      "app/**/loading.tsx",
      "app/**/not-found.tsx",
      "app/**/error.tsx",
      "middleware.ts"
    ]
  }
}
