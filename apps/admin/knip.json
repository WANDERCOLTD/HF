{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/page.tsx",
    "app/**/layout.tsx",
    "app/**/route.ts",
    "app/api/**/route.ts",
    "next-env.d.ts",
    "scripts/*.{ts,sh}",
    "tests/**/*.test.{ts,tsx}",
    "__tests__/**/*.test.{ts,tsx}",
    "e2e/**/*.spec.ts",
    "lib/wizard/__tests__/**/*.test.{ts,tsx}",
    "prisma/seed*.ts"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "contexts/**/*.{ts,tsx}",
    "scripts/**/*.ts",
    "src/**/*.{ts,tsx}"
  ],
  "ignore": [
    "**/_archived/**"
  ],
  "ignoreDependencies": [
    "@types/*",
    "tailwindcss",
    "wait-on"
  ],
  "ignoreBinaries": [
    "pkill",
    "lsof"
  ],
  "ignoreExportsUsedInFile": true,
  "next": {
    "entry": [
      "app/**/page.tsx",
      "app/**/layout.tsx",
      "app/**/route.ts",
      "app/**/loading.tsx",
      "app/**/not-found.tsx",
      "app/**/error.tsx",
      "middleware.ts"
    ]
  }
}
