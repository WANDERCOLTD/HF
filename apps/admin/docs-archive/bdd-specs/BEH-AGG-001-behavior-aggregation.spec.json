        "minimumObservations": 3,
        "aggregationRules": [
          { "sourceParameter": "BEH-CONVERSATIONAL-DEPTH", "targetProfileKey": "behavior_profile:companion:depth_engagement", "method": "threshold_mapping", "thresholds": [
            { "min": 0.75, "value": "deep", "confidence": 0.85 },
            { "min": 0.4, "max": 0.75, "value": "moderate", "confidence": 0.75 },
            { "max": 0.4, "value": "surface", "confidence": 0.7 } ] },
          { "sourceParameter": "BEH-DEPTH-PREFERENCE", "targetProfileKey": "behavior_profile:companion:depth_preference", "method": "threshold_mapping", "thresholds": [
            { "min": 0.7, "value": "intellectual", "confidence": 0.8 },
            { "min": 0.4, "max": 0.7, "value": "balanced", "confidence": 0.75 },
            { "max": 0.4, "value": "surface_chat", "confidence": 0.75 } ] },
          { "sourceParameter": "BEH-EMPATHY-RATE", "targetProfileKey": "behavior_profile:companion:empathy_level", "method": "threshold_mapping", "thresholds": [
            { "min": 0.8, "value": "mastery", "confidence": 0.85 },
