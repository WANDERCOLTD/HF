            { "min": 0.4, "max": 0.6, "value": "developing", "confidence": 0.75 },
            { "min": 0.2, "max": 0.4, "value": "emerging", "confidence": 0.7 },
            { "max": 0.2, "value": "no_evidence", "confidence": 0.8 } ] },
          { "sourceParameter": "BEH-ENERGY", "targetProfileKey": "behavior_profile:companion:energy_level", "method": "threshold_mapping", "thresholds": [
            { "min": 0.7, "value": "high", "confidence": 0.75 },
            { "min": 0.4, "max": 0.7, "value": "moderate", "confidence": 0.7 },
            { "max": 0.4, "value": "low", "confidence": 0.75 } ] },
