{
  "$schema": "./feature-spec-schema.json",
  "id": "BEH-AGG-001",
  "title": "Behavior Parameter Aggregation",
  "version": "1.0",
  "status": "Approved",
  "date": "2026-06-19",
  "domain": "behavior",
  "specType": "SYSTEM",
  "outputType": "AGGREGATE",
  "specRole": "SYNTHESISE",
  "story": {
    "asA": "personalization system",
    "iWant": "to roll up per-call BEH-* measurements into stable per-caller behavior_profile:* CallerAttributes covering companion, personality, engagement, curriculum, learning, reinforcement, supervision, onboarding, and core style signals",
    "soThat": "the adaptive loop closes for every measured BEH-* parameter — the next call's COMPOSE stage reads the rolled-up profile and the tutor adapts consistently across sessions"
  },
  "context": {
    "applies": "After MEASURE specs across the BEH-* family have written CallScore rows; runs as one AGGREGATE pass with 9 domain-grouped parameter sections — each section's aggregationRules consume that group's measurements and write to a distinct behavior_profile:* namespace",
    "dependsOn": [
      "STYLE-001-conversation-style",
      "PERS-001-personality-measurement",
      "ADAPT-PERS-001-personality-adaptation",
      "ADAPT-LEARN-001-learner-profile-adaptation",
      "ADAPT-VARK-001-modality-adaptation",
      "ADAPT-ENG-001-engagement-adaptation",
      "ADAPT-CURR-001-curriculum-adaptation",
      "CURR-001-curriculum-tracker",
      "CA-001-cognitive-activation",
      "INIT-001-caller-onboarding",
      "REW-001-reward-computation",
      "SUPV-001-agent-supervision",
      "COMP-CD-001-conversational-depth",
      "COMP-IE-001-intellectual-engagement",
      "COMP-GG-001-gentle-guidance",
      "COMP-EW-001-emotional-wellbeing",
      "COMP-INSIGHT-001-insight-cadence",
      "COMP-MC-001-memory-continuity",
      "COMP-PP-001-patience-pacing",
      "COMP-IS-001-intellectual-stimulation",
      "COMP-CG-001-cognitive-patterns",
      "COMP-RE-001-respect-experience"
    ],
    "assumptions": [
      "Most caller profiles stabilise after 3+ observations; B5 personality after 4+",
      "Recent observations are weighted more heavily (recencyWeight=0.7) than older ones in the rolling window",
      "ADAPT-stage outputs (BEH-*-ADAPTATION) are tutor-side targets; aggregating them tracks per-session fidelity (was the prescribed target honoured?)",
      "SUPV-001 scores are agent-side compliance signals; aggregating tracks the agent's per-caller compliance pattern, not the learner's behaviour"
    ]
  },
  "parameters": [
    {
      "id": "behavior_aggregate_companion",
