{
  "id": "ADAPT-LEARN-001",
  "title": "Learner Profile Adaptation",
  "version": "1.0",
  "status": "Active",
  "date": "2026-02-04",
  "domain": "learning",
  "specType": "SYSTEM",
  "outputType": "ADAPT",
  "specRole": "SYNTHESISE",
  "metadata": {
    "adaptation": {
      "inputSource": "LEARNER_PROFILE",
      "outputTarget": "CallerTarget",
      "adaptationMethod": "rule_based",
      "minimumConfidence": 0.6
    }
  },
  "story": {
    "asA": "teaching system",
    "iWant": "to adjust agent behavior based on inferred learner preferences",
    "soThat": "the learning experience feels personalized and adaptive"
  },
  "context": {
    "applies": "After learner profile has been aggregated",
    "dependsOn": [
      "LEARN-PROF-001"
    ],
    "assumptions": [
      "Learner profile exists with confidence > 0.6",
      "Behavior parameters exist in the system",
      "Adaptations are additive - don't override explicit caller settings"
    ]
  },
  "acceptanceCriteria": [
    {
      "id": "AC-ADAPT-1",
      "title": "Rule-Based Condition Evaluation",
      "given": "An ADAPT spec with adaptation rules containing conditions",
      "when": "The adapt runner evaluates each rule",
      "then": "Conditions are evaluated using the specified operator (eq, gt, gte, lt, lte, between, in). Missing operator defaults to eq for backward compatibility."
    },
    {
      "id": "AC-ADAPT-2",
      "title": "Numeric Threshold Operators",
      "given": "A condition with operator gt/gte/lt/lte and a numeric threshold",
      "when": "The profile value is a number",
      "then": "The comparison is performed correctly against the threshold. Non-numeric values always fail numeric comparisons."
    },
    {
      "id": "AC-ADAPT-3",
      "title": "Range Operator (between)",
      "given": "A condition with operator between and range { min, max }",
      "when": "The profile value is a number",
      "then": "The value is tested against the inclusive range [min, max]. Missing range field returns false."
    },
    {
      "id": "AC-ADAPT-4",
      "title": "Set Operator (in)",
      "given": "A condition with operator in and values array",
      "when": "The profile value exists",
      "then": "Returns true if the value is in the set. Works with both strings and numbers."
    },
    {
      "id": "AC-ADAPT-5",
      "title": "Data Source Selection",
      "given": "A condition with dataSource field",
      "when": "The condition is evaluated",
      "then": "Default dataSource is learnerProfile (CallerLearnerProfile fields). dataSource parameterValues reads from CallerPersonalityProfile.parameterValues (numeric measured scores)."
    },
    {
      "id": "AC-ADAPT-6",
      "title": "Adjustment Methods",
      "given": "A rule's condition matches",
      "when": "Actions are applied",
      "then": "set writes absolute value, increase adds delta (capped at 1.0), decrease subtracts delta (floored at 0.0). Target values are always clamped to [0, 1]."
    },
    {
      "id": "AC-ADAPT-7",
      "title": "Confidence from Spec Config",
      "given": "An ADAPT spec with config.defaultAdaptConfidence",
      "when": "CallerTarget entries are written",
      "then": "The confidence value comes from the spec config (not hardcoded). Default is 0.8 if not specified."
    },
    {
      "id": "AC-ADAPT-8",
      "title": "Null Profile Values",
      "given": "A profile value is null or undefined",
      "when": "Any condition targeting that key is evaluated",
      "then": "The condition returns false regardless of operator"
    }
  ],
  "parameters": [
    {
      "id": "adapt_to_learning_style",
      "name": "Adapt to Learning Style",
      "description": "Adjust behavior targets based on visual/auditory/reading learning style",
      "section": "learning_adaptation",
      "config": {
        "adaptationRules": [
          {
            "condition": {
              "profileKey": "learningStyle",
              "value": "visual"
            },
            "actions": [
              {
                "targetParameter": "example-richness",
                "adjustment": "set",
                "value": 0.9,
                "rationale": "Visual learners benefit from concrete examples"
              },
              {
                "targetParameter": "analogy-usage",
                "adjustment": "set",
                "value": 0.85,
                "rationale": "Visual learners respond well to analogies"
              },
              {
                "targetParameter": "abstract-vs-concrete",
                "adjustment": "set",
                "value": 0.2,
                "rationale": "Visual learners prefer concrete over abstract"
              }
            ]
          },
          {
            "condition": {
              "profileKey": "learningStyle",
              "value": "reading"
            },
            "actions": [
              {
                "targetParameter": "explanation-depth",
                "adjustment": "set",
                "value": 0.85,
                "rationale": "Reading learners can handle detailed explanations"
              },
              {
                "targetParameter": "example-richness",
                "adjustment": "set",
                "value": 0.5,
                "rationale": "Reading learners prefer fewer, well-explained examples"
              },
              {
                "targetParameter": "abstract-vs-concrete",
                "adjustment": "set",
                "value": 0.7,
                "rationale": "Reading learners are comfortable with abstraction"
              }
            ]
          }
        ]
      }
    },
    {
