          },
          {
            "condition": {
              "profileKey": "pacePreference",
              "value": "slow"
            },
            "actions": [
              {
                "targetParameter": "explanation-depth",
                "adjustment": "set",
                "value": 0.85,
                "rationale": "Slow pace learners benefit from thorough explanations"
              },
              {
                "targetParameter": "example-richness",
                "adjustment": "set",
                "value": 0.9,
                "rationale": "Slow pace learners need multiple examples"
              },
              {
                "targetParameter": "concept-density",
                "adjustment": "set",
                "value": 0.3,
                "rationale": "Slow pace learners need one concept at a time"
              },
              {
                "targetParameter": "repetition-frequency",
                "adjustment": "set",
                "value": 0.8,
                "rationale": "Slow pace learners benefit from repetition"
