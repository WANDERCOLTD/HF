# Front-of-house (foh) environment variables.
# Copy to .env.local and fill in. Never commit real secrets.

# App environment label surfaced in the UI (DEV | STAGING | LIVE)
NEXT_PUBLIC_APP_ENV=DEV

# Set CSP_ENFORCE=true to switch Content-Security-Policy from Report-Only to enforcing
CSP_ENFORCE=false

# --- AI providers (add as front-of-house flows need them) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# VAPI_API_KEY=
